pdatedAt\\\":\\\"2024-11-19T09:41:56.962Z\\\",\\\"createdAt\\\":\\\"2024-11-19T09:41:56.962Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/Northern%20Pottery%20File%2092\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"Northern Pottery File 92\\\",\\\"mimeType\\\":\\\"image/jpeg\\\",\\\"filesize\\\":53050,\\\"width\\\":1140,\\\"height\\\":916,\\\"focalX\\\":50,\\\"focalY\\\":50,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"description\\\":\\\"The file entails processes of making pots in Okene, Kaura, Namoda amongst others and the type of pots seen were spherical jars for water. Pottery at Daura is done at Kando, Yerdoji, Gwado and Sara, in Katagun Division, a few women make pots, in Sokoto and Bauchi, men and women make pots, in Kastina, pots are made at Kashi, Kaltungo. At Jaba, pottery is done by women and the tools used include: Touror, Kwon, Soso among others.\\\",\\\"creation\\\":\\\"1945\\\",\\\"accession\\\":\\\"1959\\\",\\\"file\\\":{\\\"id\\\":236,\\\"alt\\\":\\\"NORTHERN POTTERY FILE\\\",\\\"prefix\\\":\\\"media\\\",\\\"updatedAt\\\":\\\"2024-11-06T12:34:30.611Z\\\",\\\"createdAt\\\":\\\"2024-11-06T12:34:30.611Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/NORTHERN%20POTTERY%20FILE.pdf\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"NORTHERN POTTERY FILE.pdf\\\",\\\"mimeType\\\":\\\"application/pdf\\\",\\\"filesize\\\":2564914,\\\"width\\\":null,\\\"height\\\":null,\\\"focalX\\\":null,\\\"focalY\\\":null,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"authors\\\":\\\"K.C. Murray\\\",\\\"keyword\\\":\\\"Pottery, Northern Province, Women, Tools, Potter Industry\\\",\\\"condition\\\":\\\"Fair\\\",\\\"location\\\":\\\"National Museum Lagos\\\",\\\"rights\\\":null,\\\"identifiers\\\":\\\"NORTHERN POTTERY FILE\\\",\\\"provenance\\\":\\\"Kano, Katstina, Zaria, Plateau, Sokoto, Northern Province\\\",\\\"slug\\\":null,\\\"blockName\\\":\\\"NORTHERN POTTERY FILE\\\",\\\"blockType\\\":\\\"file\\\"},{\\\"id\\\":\\\"672b625fa0951c001ba0f70d\\\",\\\"title\\\":\\\"OBORO\\\",\\\"image\\\":{\\\"id\\\":370,\\\"alt\\\":\\\"Oboro etc_3\\\",\\\"prefix\\\":\\\"media\\\",\\\"updatedAt\\\":\\\"2024-11-19T09:45:59.509Z\\\",\\\"createdAt\\\":\\\"2024-11-19T09:45:59.509Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/Oboro%20etc_3\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"Oboro etc_3\\\",\\\"mimeType\\\":\\\"image/jpeg\\\",\\\"filesize\\\":151967,\\\"width\\\":2140,\\\"height\\\":3560,\\\"focalX\\\":50,\\\"focalY\\\":50,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"description\\\":\\\"A written report on the petitions on the Apese Village and a field report on some cultural and traditional practices in the Oboro clan such as, rejoicing at birth, sickness in the clan, etc..\\\",\\\"creation\\\":\\\"1931\\\",\\\"accession\\\":\\\"1959\\\",\\\"file\\\":{\\\"id\\\":237,\\\"alt\\\":\\\"OBORO\\\",\\\"prefix\\\":\\\"media\\\",\\\"updatedAt\\\":\\\"2024-11-06T12:35:20.436Z\\\",\\\"createdAt\\\":\\\"2024-11-06T12:35:20.436Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/OBORO.pdf\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"OBORO.pdf\\\",\\\"mimeType\\\":\\\"application/pdf\\\",\\\"filesize\\\":11273093,\\\"width\\\":null,\\\"height\\\":null,\\\"focalX\\\":null,\\\"focalY\\\":null,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"authors\\\":\\\"Surveyor of Antiquities\\\",\\\"keyword\\\":\\\"Otuto, Nkuku, Okonko, fufu, Afukwu, Oso, Apese, Inopa, Sedimentary Arrangement, Smallpox, Ofo Shrine, Swear Juju, Ekpe Society,