uta, Nigeria\\\",\\\"slug\\\":null,\\\"blockName\\\":\\\"YORUBA CALABASH FILE\\\",\\\"blockType\\\":\\\"file\\\"},{\\\"id\\\":\\\"672b6359a0951c001ba0f713\\\",\\\"title\\\":\\\"YORUBA FILE 63\\\",\\\"image\\\":{\\\"id\\\":428,\\\"alt\\\":\\\"Yoruba file 63\\\",\\\"prefix\\\":\\\"media\\\",\\\"updatedAt\\\":\\\"2024-11-21T14:22:17.281Z\\\",\\\"createdAt\\\":\\\"2024-11-21T14:22:17.281Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20file%2063-1.Yoruba%20file%2063\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"Yoruba file 63-1.Yoruba file 63\\\",\\\"mimeType\\\":\\\"image/jpeg\\\",\\\"filesize\\\":131013,\\\"width\\\":2476,\\\"height\\\":1996,\\\"focalX\\\":50,\\\"focalY\\\":50,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"description\\\":\\\"Sketches ,drawing, method and technique of making crafts in different parts of Western Nigeria(Western province) e.g. Basketry, mats, brooms, fish nets, sieves, beads, fishing instruments e. t. c.\\\",\\\"creation\\\":\\\"1932\\\",\\\"accession\\\":\\\"1959\\\",\\\"file\\\":{\\\"id\\\":426,\\\"alt\\\":\\\"Yoruba file 63.pdf\\\",\\\"prefix\\\":\\\"media\\\",\\\"updatedAt\\\":\\\"2024-11-21T14:19:55.530Z\\\",\\\"createdAt\\\":\\\"2024-11-21T14:19:55.530Z\\\",\\\"url\\\":\\\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20file%2063.pdf\\\",\\\"thumbnailURL\\\":null,\\\"filename\\\":\\\"Yoruba file 63.pdf\\\",\\\"mimeType\\\":\\\"application/pdf\\\",\\\"filesize\\\":35864221,\\\"width\\\":null,\\\"height\\\":null,\\\"focalX\\\":null,\\\"focalY\\\":null,\\\"sizes\\\":{\\\"thumb\\\":{\\\"url\\\":null,\\\"width\\\":null,\\\"height\\\":null,\\\"mimeType\\\":null,\\\"filesize\\\":null,\\\"filename\\\":null}}},\\\"authors\\\":\\\"K.C Murray\\\",\\\"keyword\\\":\\\"Raffia, Weaving, Borassus palm leaves, Jaspar Beads, Basketry, Weavon tray, Rods, Strings, Bamboo, Spear, Punting pole, Fish trap