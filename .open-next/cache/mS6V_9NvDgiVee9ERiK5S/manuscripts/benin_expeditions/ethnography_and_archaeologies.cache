ks/app/(app)/manuscripts/benin_expeditions/%5Bslug%5D/page-9190f69cebd8bb7f.js\"],\"default\"]\n7:[\"$\",\"article\",null,{\"children\":[[\"$\",\"div\",null,{\"className\":\"w-[100%]  min-h-[100vh]  overflow-hidden h-[100%] font-montserrat flex flex-col gap-4 p-8\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"sm:text-[3rem] text-[2rem] font-bold pb-8 uppercase\",\"children\":\"Ethnography and Archaeology\"}],[\"$\",\"div\",null,{\"className\":\"w-[100%] grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-8 gap-2 h-[100%]\",\"children\":[\"$\",\"$L1a\",null,{\"blocks\":[{\"id\":\"672b5e59a0951c001ba0f6fb\",\"title\":\"ADAMAWA STONE IMPLEMENT\",\"image\":{\"id\":345,\"alt\":\"Adamawa Stone Implement File\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T09:50:08.947Z\",\"createdAt\":\"2024-11-15T09:50:08.947Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Adamawa%20Stone%20Implement%20File\",\"thumbnailURL\":null,\"filename\":\"Adamawa Stone Implement File\",\"mimeType\":\"image/jpeg\",\"filesize\":49915,\"width\":960,\"height\":1212,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A report by H.J. Braunholtz on field work on stone implements by Dr. A.D.N. Bain with S.W. Walker on their visit to Dobeli. It also entails the discovery of Iron remains in Muri Division in 1832 and the field report from Yola Adamawa Province on festivals, Mumuye Tribe, Bachama Tribe, Kilba and Margi Tribes, among others.\",\"creation\":\"1931\",\"accession\":\"1959\",\"file\":{\"id\":220,\"alt\":\"ADAMAWA STONE IMPLEMENT\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:18:17.283Z\",\"createdAt\":\"2024-11-06T12:18:17.283Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/ADAMAWA%20STONE%20IMPLEMENT-2.pdf\",\"thumbnailURL\":null,\"filename\":\"ADAMAWA STONE IMPLEMENT-2.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2699037,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"H.J. Braunholtz, S.W. Walker, A.D.N. Bain\",\"keyword\":\"Stone, Implement, Discovery, Iron, Yola, Adamawa Province, Cult Objects, Calabash, Canoes, Pottery\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"ADAMAWA STONE IMPLEMENT\",\"provenance\":\"Adamawa Province\",\"slug\":null,\"blockName\":\"ADAMAWA STONE IMPLEMENT\",\"blockType\":\"file\"},{\"id\":\"672b5e90a0951c001ba0f6fc\",\"title\":\"BAMBOO AND SLATED WORK\",\"image\":{\"id\":346,\"alt\":\"Bamboo and slated work file\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T09:53:53.151Z\",\"createdAt\":\"2024-11-15T09:53:53.151Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Bamboo%20and%20slated%20work%20file\",\"thumbnailURL\":null,\"filename\":\"Bamboo and slated work file\",\"mimeType\":\"image/jpeg\",\"filesize\":249336,\"width\":2176,\"height\":2824,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A report which entails information with drawings of a tray for hanging in the roof of a house, made at Okpur Ahaba in Ngwa clan. Okeri Azu seen at Inyeogugu used for storing fish, the base is made of palm ribs details of Abo Ogugu, made at Asaga, Ohaifa. Mpokoro seen at Ihite, Ezenhitte clan, used for storing yam under the roof of a house. Alto Oko seen at Abriba, a box used for storing meat, made at Owutu Edda, Afikpo, Obeda, a tray about eighteen inches in diameter used for hanging above a fire for drying fish among others.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":221,\"alt\":\"BAMBOO AND SLATED WORK\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:18:42.649Z\",\"createdAt\":\"2024-11-06T12:18:42.649Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/BAMBOO%20AND%20SLATED%20WORK.pdf\",\"thumbnailURL\":null,\"filename\":\"BAMBOO AND SLATED WORK.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":1385987,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"National Commission For Museums and Monuments.\",\"keyword\":\"Bamboo, Roof, Abiriba, Afikpo, Ibo\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"BAMBOO AND SLATED WORK\",\"provenance\":\"Eastern Province\",\"slug\":null,\"blockName\":\"BAMBOO AND SLATED WORK\",\"blockType\":\"file\"},{\"id\":\"672b5ea7a0951c001ba0f6fd\",\"title\":\"DRAWING AND BASKETRY\",\"image\":{\"id\":363,\"alt\":\"Drawings of basketry file 111\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T08:57:17.728Z\",\"createdAt\":\"2024-11-19T08:57:17.728Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Drawings%20of%20basketry%20file%20111\",\"thumbnailURL\":null,\"filename\":\"Drawings of basketry file 111\",\"mimeType\":\"image/jpeg\",\"filesize\":53502,\"width\":1720,\"height\":2528,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The report contains a short note on the basket seen at Amokwe, Item (Bende Division) which is from Ogoja Division, it is said that people are trying to make it locally. It is used as a box and made of bunches of grass. The coiled baskets at Ekwerazu are called Egede Achara.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":222,\"alt\":\"DRAWING AND BASKETRY\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:19:11.046Z\",\"createdAt\":\"2024-11-06T12:19:11.046Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/DRAWING%20AND%20BASKETRY.pdf\",\"thumbnailURL\":null,\"filename\":\"DRAWING AND BASKETRY.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":348982,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Drawing, Basketry, Ogoja Division, Bende, Coiled Basket\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"DRAWING AND BASKETRY\",\"provenance\":\"Ogoja Division, Bende Division, Eastern Province\",\"slug\":null,\"blockName\":\"DRAWING AND BASKETRY\",\"blockType\":\"file\"},{\"id\":\"672b5ecaa0951c001ba0f6fe\",\"title\":\"EKITI FILE 60\",\"image\":{\"id\":361,\"alt\":\"Ekiti etc File 60\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T08:35:06.726Z\",\"createdAt\":\"2024-11-19T08:35:06.726Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ekiti%20etc%20File%2060\",\"thumbnailURL\":null,\"filename\":\"Ekiti etc File 60\",\"mimeType\":\"image/jpeg\",\"filesize\":242562,\"width\":1876,\"height\":2672,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Ekiti File entails lists and notes on Yoruba customs in Ilaje, Arogbo villages with description of face masks and headdresses, bronze Bell, etc. Also there are notes on plays and festivals in Ilaje Community, fishing and mat making in places like Ugbo and Mahin. The document also entails extracts from intelligence report by R.J.M. Curwen, R.A. Vosper, T.B. Bovell-Jones, J.H. Beeley and N.A.C. Weir . There is a report on Antiquities at Owo ,appointment of native authorities and notes on Ekiti Division customs and traditions.\",\"creation\":\"1943\",\"accession\":\"1959\",\"file\":{\"id\":223,\"alt\":\"EKITI FILE 60\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:20:36.487Z\",\"createdAt\":\"2024-11-06T12:20:36.487Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/EKITI%20FILE%2060.pdf\",\"thumbnailURL\":null,\"filename\":\"EKITI FILE 60.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":35249148,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray, R.J.M. Curwen, J.H. Beeley, T.B. Bovell-Jones, R.A. Vosper\",\"keyword\":\"Face masks, Headdress, Bronze Bell, Festivals, Ilaje, Ekiti Division, Ondo Division, Trade Guild, Ivories, Native Authories, Ceremonial Sword, Iron, Brass, Beadwork, Pottery, Carved Post, Egungun Masks, Idanre, Weaving\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"EKITI FILE 60\",\"provenance\":\"Ekiti Division, Ondo Division, Western Province\",\"slug\":null,\"blockName\":\"EKITI FILE 60\",\"blockType\":\"file\"},{\"id\":\"672b5fb9a0951c001ba0f700\",\"title\":\"EKITI\",\"image\":{\"id\":364,\"alt\":\"Ekiti\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T09:00:20.223Z\",\"createdAt\":\"2024-11-19T09:00:20.223Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ekiti\",\"thumbnailURL\":null,\"filename\":\"Ekiti\",\"mimeType\":\"image/jpeg\",\"filesize\":16734,\"width\":892,\"height\":1376,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A short description on objects such as, masks, iron staff and wood carving in different parts of Ekiti.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":224,\"alt\":\"EKITI\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:23:37.025Z\",\"createdAt\":\"2024-11-06T12:23:37.025Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/EKITI.pdf\",\"thumbnailURL\":null,\"filename\":\"EKITI.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":336359,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Schedules, Ekiti, Masks, Wood Carving, Iron Staff\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"EKITI\",\"provenance\":\"Ekiti District, Western Province.\",\"slug\":null,\"blockName\":\"EKITI\",\"blockType\":\"file\"},{\"id\":\"672b5fcfa0951c001ba0f701\",\"title\":\"GENERAL KILN FILE 90\",\"image\":{\"id\":366,\"alt\":\"General Kiln File 90\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T09:04:25.043Z\",\"createdAt\":\"2024-11-19T09:04:25.043Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/General%20Kiln%20File%2090\",\"thumbnailURL\":null,\"filename\":\"General Kiln File 90\",\"mimeType\":\"image/jpeg\",\"filesize\":166133,\"width\":1504,\"height\":2864,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A report on pottery drawings, drawing of a small gas kiln, planning processes of pottery, materials required, and list of labor needed. Also there are Newspaper cuttings of pottery work in this manuscript.\",\"creation\":\"1931\",\"accession\":\"1959\",\"file\":{\"id\":226,\"alt\":\"GENERAL KILN FILE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:25:47.893Z\",\"createdAt\":\"2024-11-06T12:25:47.893Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/GENERAL%20KILN%20FILE-1.pdf\",\"thumbnailURL\":null,\"filename\":\"GENERAL KILN FILE-1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":20000388,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K. C. Murray, Newsapers\",\"keyword\":\"Umuhunta, Pottery, Drawings, Newspaper, Gas Kiln\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"GENERAL KILN FILE 90\",\"provenance\":\"Umuhunta, Eastern Province, Nigeria.\",\"slug\":null,\"blockName\":\"GENERAL KILN FILE\",\"blockType\":\"file\"},{\"id\":\"672b6092a0951c001ba0f702\",\"title\":\"GENERAL MATERIAL BIRDS\",\"image\":{\"id\":348,\"alt\":\"General Material Birds etc File 88\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:08:24.977Z\",\"createdAt\":\"2024-11-15T10:08:24.977Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/General%20Material%20Birds%20etc%20File%2088\",\"thumbnailURL\":null,\"filename\":\"General Material Birds etc File 88\",\"mimeType\":\"image/jpeg\",\"filesize\":25097,\"width\":956,\"height\":1444,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Field reports complied in the Supplementary Nigerian Gazette 1937 and the Nigerian Field Journal 1939.\",\"creation\":\"1939\",\"accession\":\"1959\",\"file\":{\"id\":227,\"alt\":\"GENERAL MATERIAL BIRDS\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:27:39.665Z\",\"createdAt\":\"2024-11-06T12:27:39.665Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/GENERAL%20MATERIAL%20BIRDS.pdf\",\"thumbnailURL\":null,\"filename\":\"GENERAL MATERIAL BIRDS.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":10230705,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Supplement to the Nigeria Gazette The Journal of the Nigerian Field Society, K.C. Murray\",\"keyword\":\"Field Journal, Nigerian Gazette, Field work, K.C. Murray\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"GENERAL MATERIAL BIRDS\",\"provenance\":\"Nigeria\",\"slug\":null,\"blockName\":\"GENERAL MATERIAL BIRDS\",\"blockType\":\"file\"},{\"id\":\"672b60cba0951c001ba0f703\",\"title\":\"IBO BODY PAINTING FILE 14\",\"image\":{\"id\":356,\"alt\":\"Ibo Body Painting File 14\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T13:00:56.379Z\",\"createdAt\":\"2024-11-15T13:00:56.379Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ibo%20Body%20Painting%20File%2014\",\"thumbnailURL\":null,\"filename\":\"Ibo Body Painting File 14\",\"mimeType\":\"image/jpeg\",\"filesize\":28210,\"width\":960,\"height\":1472,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A research carried out on body painting among the Ibo people. The different ways the girls and women decorated their bodies with paintings for festivals and dances. The boys during adolescence and up to the time of joining adult society used body painting as well. The different designs include patterns that consists of a few basic shapes such as a hook, a crescent, a triangle with concave sides, a rosette, a circle or dot, a right angle and straight and curved parallel lines and crossed radiating lines.\",\"creation\":\"1971\",\"accession\":\"1959\",\"file\":{\"id\":228,\"alt\":\"IBO BODY PAINTING\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:28:36.100Z\",\"createdAt\":\"2024-11-06T12:28:36.100Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/IBO%20BODY%20PAINTING.pdf\",\"thumbnailURL\":null,\"filename\":\"IBO BODY PAINTING.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":10636701,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Ibo, Body Painting, Decoration, Umuahia, Ogoja Province\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"IBO BODY PAINTING FILE 14\",\"provenance\":\"Umuahia, Ogoja Division, Eastern Province\",\"slug\":null,\"blockName\":\"IBO BODY PAINTING\",\"blockType\":\"file\"},{\"id\":\"672b6134a0951c001ba0f704\",\"title\":\"IBO FISHING FILE\",\"image\":{\"id\":355,\"alt\":\"Ibo Fishing File 18\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T12:56:41.196Z\",\"createdAt\":\"2024-11-15T12:56:41.196Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ibo%20Fishing%20File%2018\",\"thumbnailURL\":null,\"filename\":\"Ibo Fishing File 18\",\"mimeType\":\"image/jpeg\",\"filesize\":34897,\"width\":944,\"height\":1176,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Notes on various Fish traps made in Abriba, Ogba Clan, Ekpeye Clan, Ekpeya Clan, Ukpo etc.\",\"creation\":\"1939\",\"accession\":\"1959\",\"file\":{\"id\":231,\"alt\":\"IBO FISHING FILE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:31:12.341Z\",\"createdAt\":\"2024-11-06T12:31:12.341Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/IBO%20FISHING%20FILE.pdf\",\"thumbnailURL\":null,\"filename\":\"IBO FISHING FILE.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2320603,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Ibo, Canoe, Fish Trap, Clan\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"IBO FISHING FILE\",\"provenance\":\"Eastern Province\",\"slug\":null,\"blockName\":\"IBO FISHING FILE\",\"blockType\":\"file\"},{\"id\":\"672b61aba0951c001ba0f707\",\"title\":\"IBO WOOD CARVING\",\"image\":{\"id\":354,\"alt\":\"Ibo woodcarving File 22\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T11:30:19.515Z\",\"createdAt\":\"2024-11-15T11:30:19.515Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ibo%20woodcarving%20File%2022\",\"thumbnailURL\":null,\"filename\":\"Ibo woodcarving File 22\",\"mimeType\":\"image/jpeg\",\"filesize\":29356,\"width\":972,\"height\":1468,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The file entails information on the Ekwerazu clan, their work on figure carvings, some of which are very good. Others include; painting, modelling, calabash making, fishing, baskets, etc. Agbaja clan are seen to be timid in the Division which is shown in their markets by pricing and selling articles to a European far below the real price. There are fair amount of very good religious figure carving, but its not easy to see.\",\"creation\":\"1937\",\"accession\":\"1959\",\"file\":{\"id\":232,\"alt\":\"IBO WOOD CARVING\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:32:04.681Z\",\"createdAt\":\"2024-11-06T12:32:04.681Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/IBO%20WOOD%20CARVING-1.pdf\",\"thumbnailURL\":null,\"filename\":\"IBO WOOD CARVING-1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":6320728,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Ibo, Wood Carving, Figures, Ekwerazu, Agbaja\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"IBO WOOD CARVING\",\"provenance\":\"Owerri Division, Onitsha Division, Eastern Provinces\",\"slug\":null,\"blockName\":\"IBO WOOD CARVING\",\"blockType\":\"file\"},{\"id\":\"672b61cca0951c001ba0f708\",\"title\":\"IDOMA MOULDING\",\"image\":{\"id\":439,\"alt\":\"Idoma moulding and figures\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-25T11:27:06.127Z\",\"createdAt\":\"2024-11-25T11:27:06.127Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Idoma%20moulding%20and%20figures-3.Idoma%20moulding%20and%20figures\",\"thumbnailURL\":null,\"filename\":\"Idoma moulding and figures-3.Idoma moulding and figures\",\"mimeType\":\"image/jpeg\",\"filesize\":490900,\"width\":3740,\"height\":2080,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Incidence that took place during K.C Murray's visit to some Yoruba villages, including interviews with a Yoruba elders (Adu Adamson of Inupa). Apese village about canoe making in Lagos and notes of Apese village and fishing and fishermen on Victoria Beach.\",\"creation\":\"1929\",\"accession\":\"1959\",\"file\":{\"id\":233,\"alt\":\"IDOMA MOULDING\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:33:04.270Z\",\"createdAt\":\"2024-11-06T12:33:04.270Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/IDOMA%20MOULDING.pdf\",\"thumbnailURL\":null,\"filename\":\"IDOMA MOULDING.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":25335946,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Fishing, Canoe, Apese, Yoruba\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"IDOMA MOULDING\",\"provenance\":\"Apese, Lagos, Nigeria\",\"slug\":null,\"blockName\":\"IDOMA MOULDING\",\"blockType\":\"file\"},{\"id\":\"672b6218a0951c001ba0f709\",\"title\":\"ILOJO BAR\",\"image\":{\"id\":352,\"alt\":\"Ilojo Bar_2\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:43:40.927Z\",\"createdAt\":\"2024-11-15T10:43:40.927Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ilojo%20Bar_2\",\"thumbnailURL\":null,\"filename\":\"Ilojo Bar_2\",\"mimeType\":\"image/jpeg\",\"filesize\":44477,\"width\":888,\"height\":1408,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Antiquities ordinances and evaluation of Ilojo Bar, as well as statement of Policy of the establishment of Museums in Nigeria.\",\"creation\":\"1958\",\"accession\":\"1959\",\"file\":{\"id\":234,\"alt\":\"ILOJO BAR\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:33:46.872Z\",\"createdAt\":\"2024-11-06T12:33:46.872Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/ILOJO%20BAR.pdf\",\"thumbnailURL\":null,\"filename\":\"ILOJO BAR.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":1849086,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Benard Fagg\",\"keyword\":\"Ilojo Bar, Bernard Fagg, Letters\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"ILOJO BAR\",\"provenance\":\"Lagos\",\"slug\":null,\"blockName\":\"ILOJO BAR\",\"blockType\":\"file\"},{\"id\":\"672b6231a0951c001ba0f70a\",\"title\":\"METAL WORK FILE 106\",\"image\":{\"id\":440,\"alt\":\"Metalwork file 106\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-25T12:15:56.006Z\",\"createdAt\":\"2024-11-25T12:15:56.006Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Metalwork%20file%20106\",\"thumbnailURL\":null,\"filename\":\"Metalwork file 106\",\"mimeType\":\"image/jpeg\",\"filesize\":124992,\"width\":1964,\"height\":2460,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Instruments made of Metal in ibo Culture, such as Hoes, Staff, Knives and Musical instrument, Gong\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":235,\"alt\":\"METAL WORK\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:34:09.465Z\",\"createdAt\":\"2024-11-06T12:34:09.465Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/METAL%20WORK.pdf\",\"thumbnailURL\":null,\"filename\":\"METAL WORK.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":929961,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Hoes, Knives, Staff, Gong, Igbo\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"METAL WORK FILE 106\",\"provenance\":\"Igbo, Nigeria\",\"slug\":null,\"blockName\":\"METAL WORK\",\"blockType\":\"file\"},{\"id\":\"672b6249a0951c001ba0f70b\",\"title\":\"NORTHERN POTTERY FILE\",\"image\":{\"id\":368,\"alt\":\"Northern Pottery File 92\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T09:41:56.962Z\",\"createdAt\":\"2024-11-19T09:41:56.962Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Northern%20Pottery%20File%2092\",\"thumbnailURL\":null,\"filename\":\"Northern Pottery File 92\",\"mimeType\":\"image/jpeg\",\"filesize\":53050,\"width\":1140,\"height\":916,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The file entails processes of making pots in Okene, Kaura, Namoda amongst others and the type of pots seen were spherical jars for water. Pottery at Daura is done at Kando, Yerdoji, Gwado and Sara, in Katagun Division, a few women make pots, in Sokoto and Bauchi, men and women make pots, in Kastina, pots are made at Kashi, Kaltungo. At Jaba, pottery is done by women and the tools used include: Touror, Kwon, Soso among others.\",\"creation\":\"1945\",\"accession\":\"1959\",\"file\":{\"id\":236,\"alt\":\"NORTHERN POTTERY FILE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:34:30.611Z\",\"createdAt\":\"2024-11-06T12:34:30.611Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/NORTHERN%20POTTERY%20FILE.pdf\",\"thumbnailURL\":null,\"filename\":\"NORTHERN POTTERY FILE.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2564914,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Pottery, Northern Province, Women, Tools, Potter Industry\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"NORTHERN POTTERY FILE\",\"provenance\":\"Kano, Katstina, Zaria, Plateau, Sokoto, Northern Province\",\"slug\":null,\"blockName\":\"NORTHERN POTTERY FILE\",\"blockType\":\"file\"},{\"id\":\"672b625fa0951c001ba0f70d\",\"title\":\"OBORO\",\"image\":{\"id\":370,\"alt\":\"Oboro etc_3\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T09:45:59.509Z\",\"createdAt\":\"2024-11-19T09:45:59.509Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Oboro%20etc_3\",\"thumbnailURL\":null,\"filename\":\"Oboro etc_3\",\"mimeType\":\"image/jpeg\",\"filesize\":151967,\"width\":2140,\"height\":3560,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A written report on the petitions on the Apese Village and a field report on some cultural and traditional practices in the Oboro clan such as, rejoicing at birth, sickness in the clan, etc..\",\"creation\":\"1931\",\"accession\":\"1959\",\"file\":{\"id\":237,\"alt\":\"OBORO\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:35:20.436Z\",\"createdAt\":\"2024-11-06T12:35:20.436Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/OBORO.pdf\",\"thumbnailURL\":null,\"filename\":\"OBORO.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":11273093,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Surveyor of Antiquities\",\"keyword\":\"Otuto, Nkuku, Okonko, fufu, Afukwu, Oso, Apese, Inopa, Sedimentary Arrangement, Smallpox, Ofo Shrine, Swear Juju, Ekpe Society, Crabs, Olokoro, Umuhunta, Anyanwu\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"OBORO\",\"provenance\":\"Lagos and Oboro, Eastern Province.\",\"slug\":null,\"blockName\":\"OBORO\",\"blockType\":\"file\"},{\"id\":\"672b6297a0951c001ba0f70e\",\"title\":\"P.A ALLISON\",\"image\":null,\"description\":\"The file has correspondence from Benard Fagg on behalf og P.A Allison asking for a post in the Department of Antiquity, also letters from B.D Dixey giving recommendation about P.A Allision\",\"creation\":\"1961\",\"accession\":\"1959\",\"file\":{\"id\":238,\"alt\":\"P.A ALLISON\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:35:47.625Z\",\"createdAt\":\"2024-11-06T12:35:47.625Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/P.A%20ALLISON.pdf\",\"thumbnailURL\":null,\"filename\":\"P.A ALLISON.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":1524835,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Benarg Fagg, B.D Dixey\",\"keyword\":\"Letters, Recommendation\",\"condition\":\"Fair\",\"location\":\"Nation Museum Lagos\",\"rights\":null,\"identifiers\":\"P.A ALLISON\",\"provenance\":\"Nigeria, London\",\"slug\":null,\"blockName\":\"P.A ALLISON\",\"blockType\":\"file\"},{\"id\":\"672b62aba0951c001ba0f70f\",\"title\":\"POTTERY OMU\",\"image\":{\"id\":371,\"alt\":\"Pottery Omu notes Files 68\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T09:53:03.777Z\",\"createdAt\":\"2024-11-19T09:53:03.777Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Pottery%20Omu%20notes%20Files%2068\",\"thumbnailURL\":null,\"filename\":\"Pottery Omu notes Files 68\",\"mimeType\":\"image/jpeg\",\"filesize\":319121,\"width\":2080,\"height\":2796,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The field work was carried out to study methods of making pots in different stages, such as Ikoko Orisha Apa, Odu, they are large pots used for cooking yam flour (Elubo), Enigun are small pots. This information are backed up with pictures.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":239,\"alt\":\"POTTERY OMU\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:36:19.650Z\",\"createdAt\":\"2024-11-06T12:36:19.650Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/POTTERY%20OMU.pdf\",\"thumbnailURL\":null,\"filename\":\"POTTERY OMU.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":9549772,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Pottery, Omu, Method\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"POTTERY OMU\",\"provenance\":\"Western Province\",\"slug\":null,\"blockName\":\"POTTERY OMU\",\"blockType\":\"file\"},{\"id\":\"672b6317a0951c001ba0f710\",\"title\":\"SOKOTO FILE\",\"image\":{\"id\":347,\"alt\":\"Sokoto File 44_\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:03:27.426Z\",\"createdAt\":\"2024-11-15T10:03:27.426Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Sokoto%20File%2044_\",\"thumbnailURL\":null,\"filename\":\"Sokoto File 44_\",\"mimeType\":\"image/jpeg\",\"filesize\":43758,\"width\":936,\"height\":1156,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Notes complied by C.K. Meek of field reports by C. Hercules Read, G.W. Webster on Sokoto Provincial Gazettes, Arugungun among others.\",\"creation\":\"1925\",\"accession\":\"1959\",\"file\":{\"id\":240,\"alt\":\"SOKOTO FILE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:37:58.868Z\",\"createdAt\":\"2024-11-06T12:37:58.868Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/SOKOTO%20FILE.pdf\",\"thumbnailURL\":null,\"filename\":\"SOKOTO FILE.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2238596,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"C. Hercules Read, C.K. Meek, Mr. P.G. Harris, G. W. Webster\",\"keyword\":\"Arugungun, Gazette, Notes, Sokoto Province, Antiquities, Wrestling, Grooved rocks, Artificial grooves, Musical Instruments, Calabash Decoration, Metal work, Basket, Pottery, Tumuli, Zurmi District\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"SOKOTO FILE\",\"provenance\":\"Sokoto Province\",\"slug\":null,\"blockName\":\"SOKOTO FILE\",\"blockType\":\"file\"},{\"id\":\"672b632ca0951c001ba0f711\",\"title\":\"W.B FAGG\",\"image\":{\"id\":349,\"alt\":\"W.B Fagg_2.\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:28:43.063Z\",\"createdAt\":\"2024-11-15T10:28:43.063Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/W.B%20Fagg_2\",\"thumbnailURL\":null,\"filename\":\"W.B Fagg_2\",\"mimeType\":\"image/jpeg\",\"filesize\":57241,\"width\":836,\"height\":1384,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Letters written between W.B. Fagg and K.C. Murray about their experiences on the field.\",\"creation\":\"1945\",\"accession\":\"1959\",\"file\":{\"id\":241,\"alt\":\"W.B FAGG\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:38:20.933Z\",\"createdAt\":\"2024-11-06T12:38:20.933Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/W.B%20FAGG.pdf\",\"thumbnailURL\":null,\"filename\":\"W.B FAGG.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":3468590,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"W. B. Fagg, K.C. Murray\",\"keyword\":\"Letters, Field Experience, W.B Fagg, K.C. Murray\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"W.B FAGG\",\"provenance\":\"Nigeria and Sussex\",\"slug\":null,\"blockName\":\"W.B FAGG\",\"blockType\":\"file\"},{\"id\":\"672b6343a0951c001ba0f712\",\"title\":\"YORUBA CALABASH FILE 73\",\"image\":{\"id\":441,\"alt\":\"Yoruba calabash carving File 73\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-25T12:23:24.792Z\",\"createdAt\":\"2024-11-25T12:23:24.792Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20calabash%20carving%20File%2073\",\"thumbnailURL\":null,\"filename\":\"Yoruba calabash carving File 73\",\"mimeType\":\"image/jpeg\",\"filesize\":141737,\"width\":2172,\"height\":2636,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The document consists of information on Calabash carving, Instrum,ents used for carving Calabash include: Oloko, Gangan, Aregba, Pala, Ifingba. Designs are made on the calabash, such as Incised design and raised design\\nthe Calabash in Yoruba land, particularly in Abeokuta area include, Koto, Igba Ademu, Ato, Age, Keregbe, Pakata, igba, igbaje, Igbako, Alta\",\"creation\":\"1949\",\"accession\":\"1959\",\"file\":{\"id\":242,\"alt\":\"YORUBA CALABASH FILE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:38:41.338Z\",\"createdAt\":\"2024-11-06T12:38:41.338Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20CALABASH%20FILE.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA CALABASH FILE.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2384567,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Calabash, designs, Abeokuta, Yoruba\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA CALABASH FILE 73\",\"provenance\":\"Abeokuta, Nigeria\",\"slug\":null,\"blockName\":\"YORUBA CALABASH FILE\",\"blockType\":\"file\"},{\"id\":\"672b6359a0951c001ba0f713\",\"title\":\"YORUBA FILE 63\",\"image\":{\"id\":428,\"alt\":\"Yoruba file 63\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:22:17.281Z\",\"createdAt\":\"2024-11-21T14:22:17.281Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20file%2063-1.Yoruba%20file%2063\",\"thumbnailURL\":null,\"filename\":\"Yoruba file 63-1.Yoruba file 63\",\"mimeType\":\"image/jpeg\",\"filesize\":131013,\"width\":2476,\"height\":1996,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Sketches ,drawing, method and technique of making crafts in different parts of Western Nigeria(Western province) e.g. Basketry, mats, brooms, fish nets, sieves, beads, fishing instruments e. t. c.\",\"creation\":\"1932\",\"accession\":\"1959\",\"file\":{\"id\":426,\"alt\":\"Yoruba file 63.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:19:55.530Z\",\"createdAt\":\"2024-11-21T14:19:55.530Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20file%2063.pdf\",\"thumbnailURL\":null,\"filename\":\"Yoruba file 63.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":35864221,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Raffia, Weaving, Borassus palm leaves, Jaspar Beads, Basketry, Weavon tray, Rods, Strings, Bamboo, Spear, Punting pole, Fish trap\",\"condition\":\"Fair\",\"location\":\"National Museum, Lagos\",\"rights\":null,\"identifiers\":\"YORUBA FILE 63\",\"provenance\":\"Ibadan, Abeokuta, Western Province.\",\"slug\":null,\"blockName\":\"YORUBA FILE\",\"blockType\":\"file\"},{\"id\":\"672b6374a0951c001ba0f714\",\"title\":\"YORUBA HAIR DRESSING\",\"image\":{\"id\":362,\"alt\":\"Yoruba Hairdressing file 71\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T08:39:05.804Z\",\"createdAt\":\"2024-11-19T08:39:05.804Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20Hairdressing%20file%2071\",\"thumbnailURL\":null,\"filename\":\"Yoruba Hairdressing file 71\",\"mimeType\":\"image/jpeg\",\"filesize\":236991,\"width\":2188,\"height\":2192,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A letter sent to K.C. Murray with pictures of different Yoruba hair styles in Abeokuta, Ibadan and its environs.\",\"creation\":\"1932\",\"accession\":\"1959\",\"file\":{\"id\":244,\"alt\":\"YORUBA HAIR DRESSING\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:39:28.694Z\",\"createdAt\":\"2024-11-06T12:39:28.694Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20HAIR%20DRESSING.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA HAIR DRESSING.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":1646864,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Hair Styles, Education, Schools\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA HAIR DRESSING\",\"provenance\":\"Ibadan, Abeokuta, Western Provinces\",\"slug\":null,\"blockName\":\"YORUBA HAIR DRESSING\",\"blockType\":\"file\"},{\"id\":\"672b6386a0951c001ba0f715\",\"title\":\"YORUBA MEDICINE\",\"image\":{\"id\":351,\"alt\":\"Yoruba Medicines File 96\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:38:46.196Z\",\"createdAt\":\"2024-11-15T10:38:46.196Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20Medicines%20File%2096\",\"thumbnailURL\":null,\"filename\":\"Yoruba Medicines File 96\",\"mimeType\":\"image/jpeg\",\"filesize\":154042,\"width\":2252,\"height\":2996,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Excerpts on traditional medicine for diverse purposes and its translations from Latunde's Exercise Books, complied by J.D Clark.\",\"creation\":\"1929\",\"accession\":\"1959\",\"file\":{\"id\":245,\"alt\":\"YORUBA MEDICINE\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:39:47.866Z\",\"createdAt\":\"2024-11-06T12:39:47.866Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20MEDICINE.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA MEDICINE.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2756187,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"J.D. Clark\",\"keyword\":\"Yoruba, Medicine, Translations, Latunde's Exercise Book\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA MEDICINE\",\"provenance\":\"Lagos\",\"slug\":null,\"blockName\":\"YORUBA MEDICINE\",\"blockType\":\"file\"},{\"id\":\"672b6399a0951c001ba0f716\",\"title\":\"YORUBA MINCE INDUSTRIES\",\"image\":{\"id\":350,\"alt\":\"Yoruba mince industries publication_2.\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T10:35:42.223Z\",\"createdAt\":\"2024-11-15T10:35:42.223Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20mince%20industries%20publication_2\",\"thumbnailURL\":null,\"filename\":\"Yoruba mince industries publication_2\",\"mimeType\":\"image/jpeg\",\"filesize\":155638,\"width\":1920,\"height\":2676,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Letters written between K.C. Murray from London and A.C. Callaway, from the University of Ibadan, Nigeria as well as Annual Reports from the Education Departments, concerning students interest in education on Practical Skills.\",\"creation\":\"1969\",\"accession\":\"1959\",\"file\":{\"id\":246,\"alt\":\"YORUBA MINCE INDUSTRIES\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:40:20.513Z\",\"createdAt\":\"2024-11-06T12:40:20.513Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20MINCE%20INDUSTRIES.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA MINCE INDUSTRIES.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":10517719,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray, A.C. Callaway\",\"keyword\":\"Letters, Annual Report, K.C. Murray, A.C. Callaway\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA MINCE INDUSTRIES\",\"provenance\":\"Nigeria and London\",\"slug\":null,\"blockName\":\"YORUBA MINCE INDUSTRIES\",\"blockType\":\"file\"},{\"id\":\"672b63d1a0951c001ba0f717\",\"title\":\"YORUBA OMU 67\",\"image\":{\"id\":373,\"alt\":\"Yoruba Omu File 67\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T10:10:20.175Z\",\"createdAt\":\"2024-11-19T10:10:20.175Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20Omu%20File%2067\",\"thumbnailURL\":null,\"filename\":\"Yoruba Omu File 67\",\"mimeType\":\"image/jpeg\",\"filesize\":27832,\"width\":1064,\"height\":1632,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The report entails notes on Yoruba potters such as Bandele, Adebola, Iyola and the process of pottery making. The potters generally go in groups in the early morning to get clay and help each other with the digging. Firing of pots is done at Omu Aran, pots are to be finished as black ware, notably Isasun and Awo pots are given a thorough polishing with a pebble before firing. It also includes notes on the process of firing, drying and repairs.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":247,\"alt\":\"YORUBA OMU\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:41:09.841Z\",\"createdAt\":\"2024-11-06T12:41:09.841Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20OMU.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA OMU.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":7290215,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Pottery, Omu-Aran, Ekiti\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA OMU 67\",\"provenance\":\"Omu-Aran, Ekiti Province, Nigeria.\",\"slug\":null,\"blockName\":\"YORUBA OMU\",\"blockType\":\"file\"},{\"id\":\"672b6418a0951c001ba0f719\",\"title\":\"YORUBA WEAVING\",\"image\":{\"id\":353,\"alt\":\"Yoruba Weaving File 74\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-15T11:06:55.652Z\",\"createdAt\":\"2024-11-15T11:06:55.652Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20Weaving%20File%2074\",\"thumbnailURL\":null,\"filename\":\"Yoruba Weaving File 74\",\"mimeType\":\"image/jpeg\",\"filesize\":305756,\"width\":2020,\"height\":2556,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"A field work carried out on cloth weaving in different parts of Ondo and Ilorin Province, for example: Aso Ofi.\",\"creation\":\"1933\",\"accession\":\"1959\",\"file\":{\"id\":248,\"alt\":\"YORUBA WEAVING\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:42:46.035Z\",\"createdAt\":\"2024-11-06T12:42:46.035Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%20WEAVING.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA WEAVING.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":13283411,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Yoruba, Weaving, Technology, Field work\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA WEAVING\",\"provenance\":\"Ondo and Ilorin Province\",\"slug\":null,\"blockName\":\"YORUBA WEAVING\",\"blockType\":\"file\"},{\"id\":\"672b649fa0951c001ba0f71a\",\"title\":\"YORUBA, IFE, ILLA\",\"image\":{\"id\":359,\"alt\":\"Yoruba ife and iila\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-19T08:27:47.765Z\",\"createdAt\":\"2024-11-19T08:27:47.765Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba%20ife%20and%20iila\",\"thumbnailURL\":null,\"filename\":\"Yoruba ife and iila\",\"mimeType\":\"image/jpeg\",\"filesize\":239380,\"width\":2212,\"height\":2800,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Yoruba, Ife, Illa file entails notes on; festivals, history, crafts, sites, list of mythical, historical and religious personages. The notes on bead making at Ife and Kaura Mamoda. Beads were being made at Ife thirty years ago by two women in Ilode and men of the Ajilesoro family who lived on the Ibadan side of Ife. It also consists of the Yoruba calendar , festivals like; Ifa festival, Olojo festival, as well as notes on the origin of Egungun and Oro cult.\",\"creation\":\"1944\",\"accession\":\"1959\",\"file\":{\"id\":249,\"alt\":\"YORUBA, IFE, ILLA\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-06T12:45:02.552Z\",\"createdAt\":\"2024-11-06T12:45:02.552Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA%2C%20IFE%2C%20ILLA.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA, IFE, ILLA.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":18583036,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray, W. R. Bascom\",\"keyword\":\"Yoruba, Ife, Illa, Festival, Orisha, Egungun, Newspaper\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"YORUBA, IFE, ILLA\",\"provenance\":\"Western Provinces\",\"slug\":null,\"blockName\":\"YORUBA, IFE, ILLA\",\"blockType\":\"file\"},{\"id\":\"673df2a8a7f2f7001bd2eb39\",\"title\":\"Dance and Plays file 80\",\"image\":{\"id\":421,\"alt\":\"Dance and Plays file 80\",\"prefix\":\"media\",\"updatedAt\":\"2025-02-05T11:17:13.097Z\",\"createdAt\":\"2024-11-21T10:57:31.002Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Danced%20and%20Plays%20file%2080\",\"thumbnailURL\":null,\"filename\":\"Danced and Plays file 80\",\"mimeType\":\"image/jpeg\",\"filesize\":0,\"width\":2096,\"height\":2848,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The file entails definition of dance, ritual, drama, rhythmic movement, gestures, the description of dance for instance, Bolewa Dancing, Fulani perspective of dance, Hevehe festival and dramatic dance . Also a write up on World History of the Dance by Curt Sachs, and an article written by Fela Showande on Nigerian Review(No. 58) on Keeping West Africa Alive in West African Music.\",\"creation\":\"1938\",\"accession\":\"1959\",\"file\":{\"id\":416,\"alt\":\"DANCE AND PLAYS.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-20T14:33:01.359Z\",\"createdAt\":\"2024-11-20T14:33:01.359Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/DANCE%20AND%20PLAYS.pdf\",\"thumbnailURL\":null,\"filename\":\"DANCE AND PLAYS.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":6364248,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Curt Sachs Fela Showande\",\"keyword\":\"Dance, Plays, Festivals, Bolewa, Ritual, Drama, Hevehe Festival, Fulani Dance, Dance History\",\"condition\":\"fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Dance and Plays file 80\",\"provenance\":\"West Africa\",\"slug\":null,\"blockName\":\"Dance and Plays File 80\",\"blockType\":\"file\"},{\"id\":\"673f37d70d80f5001a616706\",\"title\":\"Cameroon\",\"image\":{\"id\":422,\"alt\":\"Camerouns\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T13:39:19.609Z\",\"createdAt\":\"2024-11-21T13:39:19.609Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Camerouns\",\"thumbnailURL\":null,\"filename\":\"Camerouns\",\"mimeType\":\"image/jpeg\",\"filesize\":132941,\"width\":3188,\"height\":1984,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The File consists of Letters written by Bernard Fagg and correspondence on Cameroun and Letters \",\"creation\":\"1959\",\"accession\":\"1959\",\"file\":{\"id\":423,\"alt\":\"Cameroon.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T13:44:08.786Z\",\"createdAt\":\"2024-11-21T13:44:08.786Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Cameroon.pdf\",\"thumbnailURL\":null,\"filename\":\"Cameroon.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":3469095,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Bernard Fagg, et.al\",\"keyword\":\"Bernard Fagg, Correspondence, Cameroun, Letters\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Cameroon\",\"provenance\":\"Southern Cameroun\",\"slug\":null,\"blockName\":\"Cameroon\",\"blockType\":\"file\"},{\"id\":\"673f39930d80f5001a616708\",\"title\":\"Bernard Fagg\",\"image\":{\"id\":424,\"alt\":\"Bernard Fagg\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T13:47:36.446Z\",\"createdAt\":\"2024-11-21T13:47:36.446Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Bernard%20Fagg\",\"thumbnailURL\":null,\"filename\":\"Bernard Fagg\",\"mimeType\":\"image/jpeg\",\"filesize\":94835,\"width\":892,\"height\":1080,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The File consists of Letters written by Bernard Fagg and correspondence on Cameroun and Letters \",\"creation\":\"1950\",\"accession\":\"1959\",\"file\":{\"id\":425,\"alt\":\"Bernard Fagg.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T13:50:07.976Z\",\"createdAt\":\"2024-11-21T13:50:07.976Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Bernard%20Fagg.pdf\",\"thumbnailURL\":null,\"filename\":\"Bernard Fagg.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":7558524,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Bernard Fagg\",\"keyword\":\"Bernard Fagg, Letters, Correspondence\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Bernard Fagg\",\"provenance\":\"Nigeria\",\"slug\":null,\"blockName\":\"Bernard Fagg\",\"blockType\":\"file\"},{\"id\":\"673f419c0d80f5001a61670b\",\"title\":\"Yoruba\",\"image\":{\"id\":427,\"alt\":\"Yoruba\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:21:07.440Z\",\"createdAt\":\"2024-11-21T14:21:07.440Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Yoruba\",\"thumbnailURL\":null,\"filename\":\"Yoruba\",\"mimeType\":\"image/jpeg\",\"filesize\":466309,\"width\":2184,\"height\":2872,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Memo from K.C Murray for order cash sales of Mortice sliding door locks and town and country planning\",\"creation\":\"1947\",\"accession\":\"1947\",\"file\":{\"id\":429,\"alt\":\"YORUBA.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:23:13.506Z\",\"createdAt\":\"2024-11-21T14:23:13.506Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/YORUBA-1.pdf\",\"thumbnailURL\":null,\"filename\":\"YORUBA-1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":5644272,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Correspondence, Door Locks\",\"condition\":\"Fair\",\"location\":\"\",\"rights\":null,\"identifiers\":\"Yoruba\",\"provenance\":\"Sussex, Lagos\",\"slug\":null,\"blockName\":\"Yoruba\",\"blockType\":\"file\"},{\"id\":\"673f44d10d80f5001a61670e\",\"title\":\"Protective Warning Signs\",\"image\":{\"id\":430,\"alt\":\"Protectiver warning signs\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:34:47.594Z\",\"createdAt\":\"2024-11-21T14:34:47.594Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Protectiver%20warning%20signs\",\"thumbnailURL\":null,\"filename\":\"Protectiver warning signs\",\"mimeType\":\"image/jpeg\",\"filesize\":142828,\"width\":3140,\"height\":1832,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The Document consist of various signs of Spiritual or magical potency, placed at the edges of farm plots to protect them from the malicious and from thieves. the protection of Fire Wood and farms. it states the role of women and the intervention of dead parents\",\"creation\":\"1931\",\"accession\":\"1959\",\"file\":{\"id\":431,\"alt\":\"PROTECTIVE WARNING SIGNS.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-21T14:42:38.997Z\",\"createdAt\":\"2024-11-21T14:42:38.997Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/PROTECTIVE%20WARNING%20SIGNS.pdf\",\"thumbnailURL\":null,\"filename\":\"PROTECTIVE WARNING SIGNS.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":10903513,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Compound, Religion, Protection\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Protective Warning Signs\",\"provenance\":\"Igbo, Nigeria\",\"slug\":null,\"blockName\":\"Protective warning signs\",\"blockType\":\"file\"},{\"id\":\"6746eddcb45a9fca1b8362d7\",\"title\":\"Camerooun File 35\",\"image\":{\"id\":472,\"alt\":\"Camerooun File 35\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-27T10:01:58.323Z\",\"createdAt\":\"2024-11-27T10:01:58.323Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Camerooun%20File%2035\",\"thumbnailURL\":null,\"filename\":\"Camerooun File 35\",\"mimeType\":\"image/jpeg\",\"filesize\":462585,\"width\":2512,\"height\":1760,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The file consist of information of Bamileke community, there are various societies such as Ancient societies, which existed since the foundation of the Chieftaincy, Age groups, Societies with an economic origin. It also consist of an assessment report of Bangwa Tribal Area by H. Cadman 1922. the Traditional respect for the family head is best exemplified by the ancestor worship of the skull. Information on carvers from different clans which include: Fungom, Wum, bangwa from Fontem and History of Southern Cameroons are also included\",\"creation\":\"1922\",\"accession\":\"1959\",\"file\":{\"id\":473,\"alt\":\"CAMEROON 35\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-27T10:13:05.631Z\",\"createdAt\":\"2024-11-27T10:13:05.631Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/CAMEROON%2035\",\"thumbnailURL\":null,\"filename\":\"CAMEROON 35\",\"mimeType\":\"application/pdf\",\"filesize\":31579907,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"H.C Cadman\",\"keyword\":\"Bamileke, Societies, Carvers, Fontem, Cameroon\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Camerooun File 35\",\"provenance\":\"Camerooun, Britain\",\"slug\":null,\"blockName\":\"Cameroun File 35\",\"blockType\":\"file\"},{\"id\":\"67498bd442c4cef147911ab2\",\"title\":\"Ears and Mouth of Benin Pieces\",\"image\":{\"id\":493,\"alt\":\"Ears and Mouth of Benin Pieces\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T09:40:53.153Z\",\"createdAt\":\"2024-11-29T09:40:53.153Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/ears%20and%20mouths%20of%20benin%20pieces_1-1.jpg\",\"thumbnailURL\":null,\"filename\":\"ears and mouths of benin pieces_1-1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":28445,\"width\":972,\"height\":1488,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"An Intelligence Report having pictures and drawings of Ears and Mouth with their shapes and piercing from Benin.\",\"creation\":\"1927\",\"accession\":\"1959\",\"file\":{\"id\":494,\"alt\":\"Ears and Mouth of Benin Pieces\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T09:44:45.432Z\",\"createdAt\":\"2024-11-29T09:44:45.432Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/ears%20and%20mouths%20of%20benin%20pieces_1-1.pdf\",\"thumbnailURL\":null,\"filename\":\"ears and mouths of benin pieces_1-1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":7901385,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Benin\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Ears and Mouth of Benin Pieces\",\"provenance\":\"Benin, Southern Province, Nigeria.\",\"slug\":null,\"blockName\":\"Ears and Mouth of Benin Pieces\",\"blockType\":\"file\"},{\"id\":\"67498dae42c4cef147911ab3\",\"title\":\"Agulu File 6\",\"image\":{\"id\":495,\"alt\":\"Aulu File 6\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T09:49:13.942Z\",\"createdAt\":\"2024-11-29T09:49:13.942Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Agulu%20File%206_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Agulu File 6_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":33253,\"width\":1040,\"height\":1624,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"An Intelligence Report on the People of Agulu District and its environs in Awka. Their House settings, Crafts, Fishing, Modelling, Basketry, Carvers, Shrines, e.t.c. Summary of the Villages within and Around Agulu District were covered.\",\"creation\":\"1958\",\"accession\":\"1959\",\"file\":{\"id\":496,\"alt\":\"Aulu File 6\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T09:59:15.546Z\",\"createdAt\":\"2024-11-29T09:59:15.546Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Agulu%20File%206.pdf\",\"thumbnailURL\":null,\"filename\":\"Agulu File 6.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":15882848,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"Nzekwe .J.O, K.C. Murray\",\"keyword\":\"Agulu, Nanka, Ekwulawbia, Agu-nyi, Ofemili, baskets, crafts,\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Agulu File 6\",\"provenance\":\"Agulu, Awka Division, Eastern Province, Nigeria.\",\"slug\":null,\"blockName\":\"Agulu File 6\",\"blockType\":\"file\"},{\"id\":\"67498dd442c4cef147911ab4\",\"title\":\"Abiriba \",\"image\":{\"id\":497,\"alt\":\"Abiriba\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T10:05:51.802Z\",\"createdAt\":\"2024-11-29T10:05:51.802Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Abiriba_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Abiriba_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":123908,\"width\":2052,\"height\":3312,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Ethnographical Report by K.C. Murray on His visit to Abiriba in the Bende Area, before and afte rthe Biafra war. Giving account of how the Art work of Abiriba has been stolen and the town changes. The Report cover Letters of suggestions and Ideas on how to get the stolen Art works back home.\",\"creation\":\"1971\",\"accession\":\"1959\",\"file\":{\"id\":498,\"alt\":\"Abiriba\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-29T10:16:22.438Z\",\"createdAt\":\"2024-11-29T10:16:22.438Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Abiriba_1.pdf\",\"thumbnailURL\":null,\"filename\":\"Abiriba_1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":24910243,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray, O.A. Otisi, Godfrey Johnston,\",\"keyword\":\"Weaving, Basketry,\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Abiriba\",\"provenance\":\"Abiriba, Bende Division, Eastern Province, Nigeria.\",\"slug\":null,\"blockName\":\"Abiriba \",\"blockType\":\"file\"},{\"id\":\"674ae58b4d1b6c244bde4f95\",\"title\":\"Assorted Ibibio File 26\",\"image\":{\"id\":505,\"alt\":\"Assorted Ibibio File 26\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:16:59.253Z\",\"createdAt\":\"2024-11-30T10:16:59.253Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Assorted%20Ibibio%20Notes%20File%2026_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Assorted Ibibio Notes File 26_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":197721,\"width\":1912,\"height\":2928,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Ethnographical Report on the Ibibio crafts like the Oron Ekpu carvings, Figure Carvings, Body decoration, masks, Pottery, Fishing, Head dress carving and majorly woodwork. Brief Summaries of some Ibibio Clans. \",\"creation\":\"1938\",\"accession\":\"1959\",\"file\":{\"id\":506,\"alt\":\"Assorted Ibibio File 26\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:22:16.260Z\",\"createdAt\":\"2024-11-30T10:22:16.260Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Assorted%20Ibibio%20Notes%20File%2026.pdf\",\"thumbnailURL\":null,\"filename\":\"Assorted Ibibio Notes File 26.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":51833191,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray,\",\"keyword\":\"Haed dress, crafts,  masks, pottery, fishing, woodwork, \",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Assorted Ibibio File 26\",\"provenance\":\"Calabar, Uyo, Eket,\",\"slug\":null,\"blockName\":\"Assorted Ibibio File 26\",\"blockType\":\"file\"},{\"id\":\"674ae84c4d1b6c244bde4f96\",\"title\":\"Alayi Drawings of Baskets File 87\",\"image\":{\"id\":508,\"alt\":\"Alayi Drawings of Baskets File 87\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:30:01.000Z\",\"createdAt\":\"2024-11-30T10:30:01.000Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Alayi%20Drawings%20Of%20Baskets%20File%2087_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Alayi Drawings Of Baskets File 87_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":86108,\"width\":2024,\"height\":3016,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"An Intelligence Report giving details of list of Drawings and photos to be traced or copied. The Report gives details of Alayi's drawings of baskets of different shapes and uses.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":507,\"alt\":\"Alayi Drawings of Baskets File 87\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:29:07.802Z\",\"createdAt\":\"2024-11-30T10:29:07.802Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Alayi%20Drawings%20Of%20Baskets%20File%2087.pdf\",\"thumbnailURL\":null,\"filename\":\"Alayi Drawings Of Baskets File 87.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":21775334,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray \",\"keyword\":\"Baskets, drawings, photos, \",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Alayi Drawings of Baskets File 87\",\"provenance\":\"Eastern Province, Nigeria.\",\"slug\":null,\"blockName\":\"Alayi Drawings of Baskets File 87\",\"blockType\":\"file\"},{\"id\":\"674aeabd4d1b6c244bde4f97\",\"title\":\"Assorted Ibo File 7\",\"image\":{\"id\":509,\"alt\":\"Assorted Ibibio File 26\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:37:47.873Z\",\"createdAt\":\"2024-11-30T10:37:47.873Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Assorted%20Ibibio%20Notes%20File%2026_1-1.jpg\",\"thumbnailURL\":null,\"filename\":\"Assorted Ibibio Notes File 26_1-1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":197721,\"width\":1912,\"height\":2928,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Ethnographical Report on some Ibo Clans and their Crafts like Modelling, Painting, woodwork, mat making, hats, Figure Carving, Skin Drums, Slits Drums, Stools, e.t.c.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":510,\"alt\":\"Assorted Ibo File 7\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T10:47:23.494Z\",\"createdAt\":\"2024-11-30T10:47:23.494Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Assorted%20Ibo%20File%207_1.pdf\",\"thumbnailURL\":null,\"filename\":\"Assorted Ibo File 7_1.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":46190403,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":nu