1px]  font-montserrat transition-all font-light  p-2 gap-4 cursor-pointer bg-background\" style=\"width:180px;height:fit-content;position:relative;z-index:0;left:0;top:0;cursor:pointer\"><div style=\"width:100%\" class=\"flex flex-col gap-8 w-[100%] min-w-0 h-[100%] justify-between relative \"><span style=\"box-sizing:border-box;display:inline-block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:relative;max-width:100%\"><span style=\"box-sizing:border-box;display:block;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;max-width:100%\"><img style=\"display:block;max-width:100%;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0\" alt=\"\" aria-hidden=\"true\" src=\"data:image/svg+xml,%3csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20version=%271.1%27%20width=%27100%27%20height=%27100%27/%3e\"/></span><img alt=\"cover page\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\" decoding=\"async\" data-nimg=\"intrinsic\" class=\"object-contain\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\"/><noscript><img alt=\"cover page\" loading=\"lazy\" decoding=\"async\" data-nimg=\"intrinsic\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\" class=\"object-contain\" srcSet=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FAdamawa%2520Stone%2520Implement%2520File&amp;w=128&amp;q=75 1x, /_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FAdamawa%2520Stone%2520Implement%2520File&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FAdamawa%2520Stone%2520Implement%2520File&amp;w=256&amp;q=75\"/></noscript></span><div class=\"\"><h3 class=\"font-semibold uppercase break-words text-[0.8rem] pb-4\">ADAMAWA STONE IMPLEMENT</h3><p class=\" font-light text-[0.75rem] \"> <!-- -->A report by H.J. Braunholtz on field work on stone implements by Dr. A.D.N. Bain with S.W. Walker on their visit to Dobeli. It also entails the discovery of Iron remains in Muri Division in 1832 and the field report from Yola Adamawa Province on festivals, Mumuye Tribe, Bachama Tribe, Kilba and Margi Tribes, among others.</p></div><div class=\"flex justify-between p-4  bottom-2 \"><p>1931</p><svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\" width=\"24px\" fill=\"#1D1911\"><path d=\"M480-80 240-320l57-57 183 183 183-183 57 57L480-80ZM298-584l-58-56 240-240 240 240-58 56-182-182-182 182Z\"></path></svg></div></div></div></div><div class=\"my-16\"><div id=\"672b5e90a0951c001ba0f6fc\" class=\"flex sm:flex-row flex-col justify-between border-black border-[1px]  font-montserrat transition-all font-light  p-2 gap-4 cursor-pointer bg-background\" style=\"width:180px;height:fit-content;position:relative;z-index:0;left:0;top:0;cursor:pointer\"><div style=\"width:100%\" class=\"flex flex-col gap-8 w-[100%] min-w-0 h-[100%] justify-between relative \"><span style=\"box-sizing:border-box;display:inline-block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:relative;max-width:100%\"><span style=\"box-sizing:border-box;display:block;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;max-width:100%\"><img style=\"display:block;max-width:100%;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0\" alt=\"\" aria-hidden=\"true\" src=\"data:image/svg+xml,%3csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20version=%271.1%27%20width=%27100%27%20height=%27100%27/%3e\"/></span><img alt=\"cover page\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\" decoding=\"async\" data-nimg=\"intrinsic\" class=\"object-contain\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\"/><noscript><img alt=\"cover page\" loading=\"lazy\" decoding=\"async\" data-nimg=\"intrinsic\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\" class=\"object-contain\" srcSet=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FBamboo%2520and%2520slated%2520work%2520file&amp;w=128&amp;q=75 1x, /_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FBamboo%2520and%2520slated%2520work%2520file&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FBamboo%2520and%2520slated%2520work%2520file&amp;w=256&amp;q=75\"/></noscript></span><div class=\"\"><h3 class=\"font-semibold uppercase break-words text-[0.8rem] pb-4\">BAMBOO AND SLATED WORK</h3><p class=\" font-light text-[0.75rem] \"> <!-- -->A report which entails information with drawings of a tray for hanging in the roof of a house, made at Okpur Ahaba in Ngwa clan. Okeri Azu seen at Inyeogugu used for storing fish, the base is made of palm ribs details of Abo Ogugu, made at Asaga, Ohaifa. Mpokoro seen at Ihite, Ezenhitte clan, used for storing yam under the roof of a house. Alto Oko seen at Abriba, a box used for storing meat, made at Owutu Edda, Afikpo, Obeda, a tray about eighteen inches in diameter used for hanging above a fire for drying fish among others.</p></div><div class=\"flex justify-between p-4  bottom-2 \"><p></p><svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\" width=\"24px\" fill=\"#1D1911\"><path d=\"M480-80 240-320l57-57 183 183 183-183 57 57L480-80ZM298-584l-58-56 240-240 240 240-58 56-182-182-182 182Z\"></path></svg></div></div></div></div><div class=\"my-16\"><div id=\"672b5ea7a0951c001ba0f6fd\" class=\"flex sm:flex-row flex-col justify-between border-black border-[1px]  font-montserrat transition-all font-light  p-2 gap-4 cursor-pointer bg-background\" style=\"width:180px;height:fit-content;position:relative;z-index:0;left:0;top:0;cursor:pointer\"><div style=\"width:100%\" class=\"flex flex-col gap-8 w-[100%] min-w-0 h-[100%] justify-between relative \"><span style=\"box-sizing:border-box;display:inline-block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:relative;max-width:100%\"><span style=\"box-sizing:border-box;display:block;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;max-width:100%\"><img style=\"display:block;max-width:100%;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0\" alt=\"\" aria-hidden=\"true\" src=\"data:image/svg+xml,%3csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20version=%271.1%27%20width=%27100%27%20height=%27100%27/%3e\"/></span><img alt=\"cover page\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\" decoding=\"async\" data-nimg=\"intrinsic\" class=\"object-contain\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\"/><noscript><img alt=\"cover page\" loading=\"lazy\" decoding=\"async\" data-nimg=\"intrinsic\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\" class=\"object-contain\" srcSet=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FDrawings%2520of%2520basketry%2520file%2520111&amp;w=128&amp;q=75 1x, /_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FDrawings%2520of%2520basketry%2520file%2520111&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FDrawings%2520of%2520basketry%2520file%2520111&amp;w=256&amp;q=75\"/></noscript></span><div class=\"\"><h3 class=\"font-semibold uppercase break-words text-[0.8rem] pb-4\">DRAWING AND BASKETRY</h3><p class=\" font-light text-[0.75rem] \"> <!-- -->The report contains a short note on the basket seen at Amokwe, Item (Bende Division) which is from Ogoja Division, it is said that people are trying to make it locally. It is used as a box and made of bunches of grass. The coiled baskets at Ekwerazu are called Egede Achara.</p></div><div class=\"flex justify-between p-4  bottom-2 \"><p></p><svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\" width=\"24px\" fill=\"#1D1911\"><path d=\"M480-80 240-320l57-57 183 183 183-183 57 57L480-80ZM298-584l-58-56 240-240 240 240-58 56-182-182-182 182Z\"></path></svg></div></div></div></div><div class=\"my-16\"><div id=\"672b5ecaa0951c001ba0f6fe\" class=\"flex sm:flex-row flex-col justify-between border-black border-[1px]  font-montserrat transition-all font-light  p-2 gap-4 cursor-pointer bg-background\" style=\"width:180px;height:fit-content;position:relative;z-index:0;left:0;top:0;cursor:pointer\"><div style=\"width:100%\" class=\"flex flex-col gap-8 w-[100%] min-w-0 h-[100%] justify-between relative \"><span style=\"box-sizing:border-box;display:inline-block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:relative;max-width:100%\"><span style=\"box-sizing:border-box;display:block;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;max-width:100%\"><img style=\"display:block;max-width:100%;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0\" alt=\"\" aria-hidden=\"true\" src=\"data:image/svg+xml,%3csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20version=%271.1%27%20width=%27100%27%20height=%27100%27/%3e\"/></span><img alt=\"cover page\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\" decoding=\"async\" data-nimg=\"intrinsic\" class=\"object-contain\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\"/><noscript><img alt=\"cover page\" loading=\"lazy\" decoding=\"async\" data-nimg=\"intrinsic\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\" class=\"object-contain\" srcSet=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FEkiti%2520etc%2520File%252060&amp;w=128&amp;q=75 1x, /_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FEkiti%2520etc%2520File%252060&amp;w=256&amp;q=75 2x\" src=\"/_next/image?url=https%3A%2F%2Flagosmuseumarchives.ng%2Fapi%2Fmedia%2Ffile%2FEkiti%2520etc%2520File%252060&amp;w=256&amp;q=75\"/></noscript></span><div class=\"\"><h3 class=\"font-semibold uppercase break-words text-[0.8rem] pb-4\">EKITI FILE 60</h3><p class=\" font-light text-[0.75rem] \"> <!-- -->Ekiti File entails lists and notes on Yoruba customs in Ilaje, Arogbo villages with description of face masks and headdresses, bronze Bell, etc. Also there are notes on plays and festivals in Ilaje Community, fishing and mat making in places like Ugbo and Mahin. The document also entails extracts from intelligence report by R.J.M. Curwen, R.A. Vosper, T.B. Bovell-Jones, J.H. Beeley and N.A.C. Weir . There is a report on Antiquities at Owo ,appointment of native authorities and notes on Ekiti Division customs and traditions.</p></div><div class=\"flex justify-between p-4  bottom-2 \"><p>1943</p><svg xmlns=\"http://www.w3.org/2000/svg\" height=\"24px\" viewBox=\"0 -960 960 960\" width=\"24px\" fill=\"#1D1911\"><path d=\"M480-80 240-320l57-57 183 183 183-183 57 57L480-80ZM298-584l-58-56 240-240 240 240-58 56-182-182-182 182Z\"></path></svg></div></div></div></div><div class=\"my-16\"><div id=\"672b5fb9a0951c001ba0f700\" class=\"flex sm:flex-row flex-col justify-between border-black border-[1px]  font-montserrat transition-all font-light  p-2 gap-4 cursor-pointer bg-background\" style=\"width:180px;height:fit-content;position:relative;z-index:0;left:0;top:0;cursor:pointer\"><div style=\"width:100%\" class=\"flex flex-col gap-8 w-[100%] min-w-0 h-[100%] justify-between relative \"><span style=\"box-sizing:border-box;display:inline-block;overflow:hidden;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;position:relative;max-width:100%\"><span style=\"box-sizing:border-box;display:block;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0;max-width:100%\"><img style=\"display:block;max-width:100%;width:initial;height:initial;background:none;opacity:1;border:0;margin:0;padding:0\" alt=\"\" aria-hidden=\"true\" src=\"data:image/svg+xml,%3csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20version=%271.1%27%20width=%27100%27%20height=%27100%27/%3e\"/></span><img alt=\"cover page\" src=\"data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7\" decoding=\"async\" data-nimg=\"intrinsic\" class=\"object-contain\" style=\"position:absolute;top:0;left:0;bottom:0;right:0;box-sizing:border-box;padding:0;border:none;margin:auto;display:block;width:0;height:0;min-width:100%;max-width:100%;min-height:100%;max-height:100%\"/><noscript><img alt=\"cover page\" loading=\"lazy\" decoding=\"async\" data-nimg=\"