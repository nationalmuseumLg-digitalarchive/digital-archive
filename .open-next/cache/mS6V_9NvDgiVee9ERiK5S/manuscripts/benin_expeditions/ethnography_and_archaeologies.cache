ockName\":\"Benin\",\"blockType\":\"file\"},{\"id\":\"674af0664d1b6c244bde4f99\",\"title\":\"Blacksmith File 70\",\"image\":{\"id\":514,\"alt\":\"Blacksmith File 70\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T11:04:54.451Z\",\"createdAt\":\"2024-11-30T11:04:54.451Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Blacksmith%20File%2070_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Blacksmith File 70_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":197430,\"width\":1868,\"height\":2924,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"An Ethnographical Report on Blacksmiths, pictures of metal works done at Omu, Iseyin, Abeokuta, e.t.c. List of Brass Smith also at Abeokuta was captured.\",\"creation\":null,\"accession\":\"1959\",\"file\":{\"id\":513,\"alt\":\"Blacksmith File 70\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T11:03:20.835Z\",\"createdAt\":\"2024-11-30T11:03:20.835Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Blacksmith%20File%2070.pdf\",\"thumbnailURL\":null,\"filename\":\"Blacksmith File 70.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":17394872,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Blacksmith bellows, Omu, Sango, Osanyin, \",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Blacksmiths File 70\",\"provenance\":\"Omu, Iseyin, Abeokuta, Western Province, Nigeria.\",\"slug\":null,\"blockName\":\"Blacksmith File 70\",\"blockType\":\"file\"},{\"id\":\"674af24a4d1b6c244bde4f9a\",\"title\":\"Dahomey File 56\",\"image\":{\"id\":515,\"alt\":\"Dahomey\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T11:14:16.970Z\",\"createdAt\":\"2024-11-30T11:14:16.970Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/dahomey%20file%2056_1.jpg\",\"thumbnailURL\":null,\"filename\":\"dahomey file 56_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":24942,\"width\":1024,\"height\":1620,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Ethnographical Report on Dahomey about their crafts, pottery at Abomey, Senegal, weaving, Knitting, Dyeing, Woodwork, Brasswork.\",\"creation\":\"1935\",\"accession\":\"1959\",\"file\":{\"id\":516,\"alt\":\"Dahomey\",\"prefix\":\"media\",\"updatedAt\":\"2024-11-30T11:21:10.777Z\",\"createdAt\":\"2024-11-30T11:21:10.777Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/dahomey%20file%2056_13.pdf\",\"thumbnailURL\":null,\"filename\":\"dahomey file 56_13.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":2941363,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C. Murray\",\"keyword\":\"Pottery, Weaving, Knitting, Dyeing, Woodwork, Brasswork,\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Dahomey\",\"provenance\":\"Dahomey, Western Province, Nigeria.\",\"slug\":null,\"blockName\":\"Dahomey File 56\",\"blockType\":\"file\"},{\"id\":\"674da9a2daf7530003e4b938\",\"title\":\"Ijebu File 58\",\"image\":{\"id\":528,\"alt\":\"Ijebu File 58\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-02T12:42:54.112Z\",\"createdAt\":\"2024-12-02T12:42:54.112Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ijebu%20File%2058\",\"thumbnailURL\":null,\"filename\":\"Ijebu File 58\",\"mimeType\":\"image/jpeg\",\"filesize\":101398,\"width\":1736,\"height\":2652,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Information on Ijebu Province on carvings and Headdresses in Ile Erinmo, drawings of Obeje, Erimo Makun. Also there's information on metal work, different types of articles made of Iron, Wood carving Ode-Omi which is a small, low lying village built on a clearing close to the water. Information also on the village of Imobi involved in carvings. ancient Bronze Articles at Ijebu Province, Basketry and fishing utensils antiquities of shrine of Odudua, Osun, Igbokoku, Ijebu Ife and Ijebu Igbo.\",\"creation\":\"1948\",\"accession\":\"1959\",\"file\":{\"id\":530,\"alt\":\"Ijebu file 58.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-02T12:57:07.897Z\",\"createdAt\":\"2024-12-02T12:57:07.897Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ijebu%20file%2058.pdf\",\"thumbnailURL\":null,\"filename\":\"Ijebu file 58.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":3920848,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray, Isaiah Odukoya\",\"keyword\":\"Headdresses, Metal Work, Carving, Fishing utensils\",\"condition\":\"fair\",\"location\":\"National Musem Lagos\",\"rights\":null,\"identifiers\":\"Ijebu File 58\",\"provenance\":\"Ijebu, Nigeria\",\"slug\":null,\"blockName\":\"Ijebu File\",\"blockType\":\"file\"},{\"id\":\"6750cb6f87e2467c265fec63\",\"title\":\"Bauchii and Gombe File 52\",\"image\":{\"id\":571,\"alt\":\"Bauchi & Gombe file 52\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-04T12:39:59.353Z\",\"createdAt\":\"2024-12-04T12:39:59.353Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Bauchi%20%26%20Gombe%20file%2052-2.Bauchi%20%26%20Gombe%20file%2052\",\"thumbnailURL\":null,\"filename\":\"Bauchi & Gombe file 52-2.Bauchi & Gombe file 52\",\"mimeType\":\"image/jpeg\",\"filesize\":246215,\"width\":2892,\"height\":2076,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Information on the History of the Kaltungo which lies around the foot of a hill from which the these include: cowries, but their purpose seems to have been mainly for making marriage payments. No figure carvings or wooden masks are made by the Kaltungo people\",\"creation\":\"1946\",\"accession\":\"1959\",\"file\":{\"id\":572,\"alt\":\"Bauchi & Gombe file 52.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-04T12:45:55.305Z\",\"createdAt\":\"2024-12-04T12:45:55.305Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Bauchi%20%26%20Gombe%20file%2052.pdf\",\"thumbnailURL\":null,\"filename\":\"Bauchi & Gombe file 52.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":14741315,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"R.O Ranage, Walwyn, C.K.Meek\",\"keyword\":\"Kaltungo, Carving, Currency, Colonial\",\"condition\":\"Fir\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Bauchii and Gombe File 52\",\"provenance\":\"Bauchi, Gombe, Nigeria\",\"slug\":null,\"blockName\":\"Bauchi and Gombe File 52\",\"blockType\":\"file\"},{\"id\":\"675ed14e8f9574f4305ca831\",\"title\":\"Fishing Affairs 5\",\"image\":{\"id\":622,\"alt\":\"Fishing Affair 5_2.jpg\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:01:46.531Z\",\"createdAt\":\"2024-12-15T13:01:46.531Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Fishing%20Affair%205_2.jpg\",\"thumbnailURL\":null,\"filename\":\"Fishing Affair 5_2.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":369504,\"width\":1988,\"height\":2956,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The file consists of information on Ijebu Province in carvings and Head-dresses in the Ile Erinmo, drawings of Obeje Imobi, Akarija, obeje, Erimo Makun, their metal works of which there are different types of articles made of Iron, Wood Carving Ode-Omi which is a small low lying village built on a clearing close to the water. Villages of Imobi are also involved in carvings, Anicent Bronze, articles at Ijebu Province, Basketry and fishing utensils. Antiquities of shrine of odudua, Osun, Igbokoku, Ijebu Ife and Ijebu Igbo.\",\"creation\":\"1946\",\"accession\":\"1959\",\"file\":{\"id\":621,\"alt\":\"Fishing Affair 5_10.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T12:57:30.563Z\",\"createdAt\":\"2024-12-15T12:57:30.563Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Fishing%20Affair%205_10.pdf\",\"thumbnailURL\":null,\"filename\":\"Fishing Affair 5_10.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":36949022,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Ijebu Province, basketry, Fishing Utensils\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Fishing Affair 5\",\"provenance\":\"Ijebu Province, Lagos\",\"slug\":null,\"blockName\":\"Fishing Affair5\",\"blockType\":\"file\"},{\"id\":\"675ed3838f9574f4305ca832\",\"title\":\"Ijebu Okitipupa File 75\",\"image\":{\"id\":623,\"alt\":\"Ijebu Okitipupa File 75\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:05:00.181Z\",\"createdAt\":\"2024-12-15T13:05:00.181Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ijebu%20Okitipupa%20File%2075-3.Ijebu%20Okitipupa%20File%2075\",\"thumbnailURL\":null,\"filename\":\"Ijebu Okitipupa File 75-3.Ijebu Okitipupa File 75\",\"mimeType\":\"image/jpeg\",\"filesize\":30397,\"width\":880,\"height\":1168,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"Information on History of the Ikales came originally from Benin. The benin race migrated from Ife during the 14th century and the Ikales are descendants of these people. Their festivals include: Are Festival, worshipping of ancient, Ogwa, a place set aside by the Abodi and the Olojo for the worshipping of their ancestors. The Ikale year starts in March.. Extracts of Report by R.J.M shows the Ijaw people do carving for purely decorative as opposed to religious reasons, some of this work is done by husbands for their wives but either is done as decoration for their house. The file also consists of the history of Ilaje district, population of which is slitted into Ugbo, mahin, Etikan. Ilaje is known for fishing activities of which tools like Iyanman (Basket) Eri or Awo (Large net), Egbo (Stick or string) Ojigon is used., B.J.A Matthews explains Mat making in Ilaje, Etu ore or ifin, this include: Ore Olona, ore olojiokun made from coarse grass, ore lafala and Ejiko. There are also headdress of different styles,\",\"creation\":\"1932\",\"accession\":\"1959\",\"file\":{\"id\":624,\"alt\":\"Ijebu okitipupa file 75.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:10:22.668Z\",\"createdAt\":\"2024-12-15T13:10:22.668Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ijebu%20okitipupa%20file%2075.pdf\",\"thumbnailURL\":null,\"filename\":\"Ijebu okitipupa file 75.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":22317566,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray\",\"keyword\":\"Ikale, Festivals, Wood Carving, Mat making\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Ijebu okitipupa file 75.pdf\",\"provenance\":\"Ikale, Okitipupa, Ijebu, Nigeria\",\"slug\":null,\"blockName\":\"Ijebu Okitipupa File 75\",\"blockType\":\"file\"},{\"id\":\"675ed63b8f9574f4305ca833\",\"title\":\"Benue Plateau File 53\",\"image\":{\"id\":625,\"alt\":\"Benue Plateau File 53\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:15:58.529Z\",\"createdAt\":\"2024-12-15T13:15:58.529Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Benue%20Plateau%20File%2053_1.jpg\",\"thumbnailURL\":null,\"filename\":\"Benue Plateau File 53_1.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":85319,\"width\":2956,\"height\":1864,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"The Pagan head-dresses in the benue style mostly appear to be the work of competent career following traditional forms, the file also consists of Bargesh (Kakari Tribe), it lies among rocky hills in a valley about 600 feet down from the Plateau. The huts are circular and impressively tall with a stone course about two third of the way up for on upper story. The Anaguta Tribe is a small Tribe living north-east of Jos. The hausa made post have replaced the local industry which is now practically abandoned. Some houses have moulded decorations. Representations of cows or antelopes. Simithy is a low, round shed tools include: Hausa type bellows and a few European hammers. Birom Tribe, a feature are the high defensive amphobia hedges leading to and surrounding the villages\",\"creation\":\"1940-45\",\"accession\":\"1959\",\"file\":{\"id\":626,\"alt\":\"Benue Plateau File 53.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:17:37.077Z\",\"createdAt\":\"2024-12-15T13:17:37.077Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Benue%20Plateau%20File%2053.pdf\",\"thumbnailURL\":null,\"filename\":\"Benue Plateau File 53.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":17725182,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C.Murray\",\"keyword\":\"Headdress, Anaguta tribe, Birom Tribe, Houses\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Benue Plateau File 53\",\"provenance\":\"Benue, Plauteau, Nigeria\",\"slug\":null,\"blockName\":\"Benue Plateau File 53\",\"blockType\":\"file\"},{\"id\":\"675ed78a8f9574f4305ca834\",\"title\":\"Fishing Affairs 10\",\"image\":{\"id\":627,\"alt\":\"Fishing Affairs\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:23:31.825Z\",\"createdAt\":\"2024-12-15T13:23:31.825Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Fishing%20Affairs\",\"thumbnailURL\":null,\"filename\":\"Fishing Affairs\",\"mimeType\":\"image/jpeg\",\"filesize\":189610,\"width\":1832,\"height\":2808,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"This file entails documents on the travelers, letters written to K.C Murray on the damage to nets by travelers, other challenges such as the aversion of shark to dead sharks, shark fishing was always bad in the waters where a dead shark was found also there has been records of successes and how unity was fostered among the Fishermen. Correspodence from Apese Fishermen Association to K.C Murray,as well as other movements of shipping\",\"creation\":\"1961\",\"accession\":\"1959\",\"file\":{\"id\":628,\"alt\":\"Fishing Affairs\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-15T13:29:32.869Z\",\"createdAt\":\"2024-12-15T13:29:32.869Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Fishing%20Affairs-1.Fishing%20Affairs\",\"thumbnailURL\":null,\"filename\":\"Fishing Affairs-1.Fishing Affairs\",\"mimeType\":\"application/pdf\",\"filesize\":41750662,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"authors\":\"K.C Murray, Apese Fishermen Association\",\"keyword\":\"Fishermen, Canoe, Apese Association\",\"condition\":\"Fair\",\"location\":\"National Museum Lagos\",\"rights\":null,\"identifiers\":\"Fishing Affairs\",\"provenance\":\"Apese, Lagos, Nigeia\",\"slug\":null,\"blockName\":\"Fishing Affairs 10\",\"blockType\":\"file\"},{\"id\":\"67609ebe4e864a2dff254f7f\",\"title\":\"Ife\",\"image\":{\"id\":633,\"alt\":\"Ife_2.\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-16T21:51:46.042Z\",\"createdAt\":\"2024-12-16T21:51:46.042Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ife_2\",\"thumbnailURL\":null,\"filename\":\"Ife_2\",\"mimeType\":\"image/jpeg\",\"filesize\":85626,\"width\":1380,\"height\":840,\"focalX\":50,\"focalY\":50,\"sizes\":{\"thumb\":{\"url\":null,\"width\":null,\"height\":null,\"mimeType\":null,\"filesize\":null,\"filename\":null}}},\"description\":\"the file entails information on benin Museum administration, the antiquities department T.F 207. it also gives information about Lajuwa, qualities which marks the classic brass and terracotta heads of ife, these qualities do not llie in the expression of character, but in formal aspects, the representation of shapes. although the heads do not represnt the charater of personality, they do represent the character of form and thereby convince that the representation it consists or some unpublished terracotta heads of the ife in the history of West African sculpture details about Frobenius and Ile-ife\",\"creation\":\"1943\",\"accession\":\"1959\",\"file\":{\"id\":630,\"alt\":\"Ife.pdf\",\"prefix\":\"media\",\"updatedAt\":\"2024-12-16T21:44:22.147Z\",\"createdAt\":\"2024-12-16T21:44:22.147Z\",\"url\":\"https://lagosmuseumarchives.ng/api/media/file/Ife.pdf\",\"thumbnailURL\":null,\"filename\":\"Ife.pdf\",\"mimeType\":\"application/pdf\",\"filesize\":8506321,\"width\":null,\"height\":null,\"fo