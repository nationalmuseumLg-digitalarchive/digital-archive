{
  "name": "museum",
  "version": "1.1.0",
  "description": "national museum lagos digital archives",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:cloudflare": "npx opennextjs-cloudflare build",
    "deploy:cloudflare": "npx opennextjs-cloudflare deploy",
    "build": "payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next --turbo",
    "install:cloudflare": "npm install --legacy-peer-deps --no-package-lock",
    "install:local": "npm install --legacy-peer-deps",
    "postinstall": "echo 'Installation complete - ensure --legacy-peer-deps was used'",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate:ethnographic": "tsx scripts/migrate-ethnographic.ts",
    "link:ethnographic": "tsx scripts/link-ethnographic.ts"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "20.12.2",
    "npm": "10.9.2"
  },
  "overrides": {
    "@payloadcms/next": "3.72.0",
    "@payloadcms/plugin-search": "3.72.0",
    "@payloadcms/richtext-lexical": "3.72.0",
    "@payloadcms/db-postgres": "3.72.0",
    "@payloadcms/plugin-nested-docs": "3.72.0",
    "@payloadcms/storage-s3": "3.72.0",
    "@payloadcms/ui": "3.72.0",
    "@payloadcms/graphql": "3.72.0",
    "@payloadcms/drizzle": "3.72.0",
    "payload": "3.72.0",
    "yjs": "13.6.30",
    "monaco-editor": "0.55.1",
    "dompurify": "3.2.7",
    "marked": "14.0.0",
    "@types/trusted-types": "2.0.7",
    "ajv": "8.17.1",
    "jose": "5.9.6",
    "scmp": "2.1.0",
    "undici": "7.18.2",
    "picomatch": "4.0.4",
    "lib0": "0.2.117",
    "isomorphic.js": "0.2.5",
    "zod": "3.25.76",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "merge-refs": "1.3.0"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.17.4",
    "@payloadcms/db-postgres": "3.72.0",
    "@payloadcms/next": "3.72.0",
    "@payloadcms/plugin-nested-docs": "3.72.0",
    "@payloadcms/plugin-search": "3.72.0",
    "@payloadcms/richtext-lexical": "3.72.0",
    "@payloadcms/storage-s3": "3.72.0",
    "algoliasearch": "^5.5.3",
    "axios": "^1.7.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.4.10",
    "graphql": "^16.8.1",
    "instantsearch.css": "^8.5.1",
    "instantsearch.js": "^4.74.1",
    "neonctl": "^2.20.2",
    "next": "^15.5.9",
    "payload": "3.72.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-instantsearch": "^7.15.4",
    "react-instantsearch-nextjs": "^0.4.5",
    "react-pdf": "^9.1.1",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.9",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.6.2",
    "wrangler": "^4.79.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.3",
      "@types/react-dom": "19.2.3"
    }
  }
}
