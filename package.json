{
  "name": "museum",
  "version": "1.1.0",
  "description": "national museum lagos digital archives",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next build ",
    "dev": "payload generate:importmap && cross-env NODE_OPTIONS=--no-deprecation next --turbo",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "migrate:ethnographic": "tsx scripts/migrate-ethnographic.ts",
    "link:ethnographic": "tsx scripts/link-ethnographic.ts",
    "recover:orphaned": "tsx scripts/recover-orphaned-files.ts"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.17.4",
    "@payloadcms/db-postgres": "^3.72.0",
    "@payloadcms/next": "^3.72.0",
    "@payloadcms/plugin-nested-docs": "^3.72.0",
    "@payloadcms/plugin-search": "^3.72.0",
    "@payloadcms/richtext-lexical": "^3.72.0",
    "@payloadcms/storage-s3": "^3.72.0",
    "algoliasearch": "^5.5.3",
    "axios": "^1.7.7",
    "cross-env": "^7.0.3",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.4.10",
    "graphql": "^16.8.1",
    "instantsearch.css": "^8.5.1",
    "instantsearch.js": "^4.74.1",
    "neonctl": "^2.20.2",
    "next": "^15.5.9",
    "payload": "^3.72.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-instantsearch": "^7.15.4",
    "react-instantsearch-nextjs": "^0.4.5",
    "react-pdf": "^9.1.1",
    "sharp": "0.32.6",
    "zustand": "^5.0.0-rc.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/react": "npm:types-react@19.0.0-rc.0",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.9",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.6.2"
  },
  "engines": {
    "node": "^20.12.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "npm:types-react@19.0.0-rc.0",
      "@types/react-dom": "npm:types-react-dom@19.0.0-rc.0"
    }
  },
  "overrides": {
    "@types/react": "npm:types-react@19.0.0-rc.0",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.0"
  }
}
